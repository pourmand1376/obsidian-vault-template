{
  "command_timeout": 5,
  "templates_folder": "Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "Templates/scripts",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Journaling/DailyNotes",
      "template": "Templates/4-Daily Notes Template.md"
    },
    {
      "folder": "Journaling/WeeklyNotes",
      "template": "Templates/5-Weekly Notes Template.md"
    },
    {
      "folder": "Journaling/MonthlyNotes",
      "template": "Templates/6-Monthly Notes Template.md"
    },
    {
      "folder": "Journaling/QuarterlyNotes",
      "template": "Templates/7-Quarterly Notes Template.md"
    },
    {
      "folder": "Journaling/YearlyNotes",
      "template": "Templates/8-Yearly Notes Template.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    ""
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [
    {
      "folder": ""
    }
  ]
}